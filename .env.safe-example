# Environment Variables (Safe Example)
# Copy this file to .env and fill in your values

# Public keys (safe to include in client-side code)
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# ⚠️ NEVER include these in client code or .env:
# SUPABASE_SERVICE_ROLE_KEY - server-side only (auto-injected in edge functions)
# SUPABASE_DB_URL - server-side only (auto-injected in edge functions)
# DATABASE_PASSWORD - never expose
